# =============================================================================
# 数据库 (Railway 会自动提供此变量，连接 PostgreSQL 插件)
# =============================================================================
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# =============================================================================
# Redis (Railway 会自动提供此变量，连接 Redis 插件)
# =============================================================================
REDIS_URL="redis://default:password@host:6379"

# =============================================================================
# 应用配置
# =============================================================================
NODE_ENV="production"

# 部署后 Railway 分配的公网域名，例如 https://drama-cps.up.railway.app
NEXT_PUBLIC_APP_URL="https://your-app.up.railway.app"

# 默认 CPS 跳转链接（用户未匹配 Drama 时的兜底 URL）
DEFAULT_CPS_URL="https://example.com"

# =============================================================================
# Facebook / Meta API (前往 https://developers.facebook.com 创建应用获取)
# =============================================================================
META_APP_ID="your_facebook_app_id"
META_APP_SECRET="your_facebook_app_secret"
META_API_VERSION="v19.0"

# 是否使用 Mock 模式（开发测试时填 true，生产填 false）
USE_META_MOCK="false"

# =============================================================================
# Worker 配置 (可选)
# =============================================================================
PUBLISH_WORKER_CONCURRENCY="5"

# JWT 签发密钥（用于页面 token 验证，随机字符串即可）
JWT_SECRET="change_this_to_a_long_random_secret_string"
