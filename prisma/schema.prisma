// This is your Prisma schema file
// Learn more about Prisma: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================
// 用户和认证
// ===========================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  role          UserRole  @default(ADMIN)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
}

enum UserRole {
  ADMIN
  MANAGER
  VIEWER
}

// ===========================================
// Facebook 主页管理
// ===========================================

model FacebookPage {
  id              String        @id @default(cuid())
  pageId          String        @unique
  pageName        String
  accessToken     String
  tokenExpiresAt  DateTime?
  status          PageStatus    @default(ACTIVE)
  
  // 主页基本信息
  coverUrl        String?
  profilePicUrl   String?
  fansCount       Int           @default(0)
  category        String?
  
  // 业务配置
  niche           String?       // 赛道：情感、逆袭、甜宠等
  region          String?       // 地区：US、SEA、LATAM等
  language        String?       // 语言：en、es、pt等
  timezone        String        @default("America/New_York")
  tags            String[]      // 自定义标签
  
  // 发布限制
  dailyPostLimit  Int           @default(10)
  todayPostCount  Int           @default(0)
  lastPostAt      DateTime?
  
  // 健康分
  healthScore     Int           @default(100)
  consecutiveFailures Int       @default(0)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // 关联
  publishTasks    PublishTask[]
  performanceLogs PerformanceLog[]
  clickLogs       ClickLog[]
  healthLogs      PageHealthLog[]

  @@index([status])
  @@index([niche])
  @@index([region])
  @@map("facebook_pages")
}

enum PageStatus {
  ACTIVE
  PAUSED
  WARNING
  RESTRICTED
  BANNED
}

// ===========================================
// 短剧和视频素材
// ===========================================

model Drama {
  id          String    @id @default(cuid())
  dramaName   String
  description String?
  coverUrl    String?
  language    String    @default("en")
  tags        String[]
  cpsBaseUrl  String?   // CPS 基础链接
  status      DramaStatus @default(ACTIVE)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  videos      Video[]

  @@index([status])
  @@map("dramas")
}

enum DramaStatus {
  ACTIVE
  ARCHIVED
  BANNED
}

model Video {
  id          String      @id @default(cuid())
  dramaId     String
  title       String
  description String?
  fileUrl     String
  coverUrl    String?
  duration    Int?        // 时长（秒）
  language    String      @default("en")
  tags        String[]
  metadata    Json?       // 额外元数据
  status      VideoStatus @default(DRAFT)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // 关联
  drama       Drama       @relation(fields: [dramaId], references: [id])
  variants    VideoVariant[]
  publishTasks PublishTask[]
  performanceLogs PerformanceLog[]
  clickLogs   ClickLog[]

  @@index([dramaId])
  @@index([status])
  @@map("videos")
}

enum VideoStatus {
  DRAFT
  READY
  ARCHIVED
  BANNED
}

// ===========================================
// 视频变体
// ===========================================

model VideoVariant {
  id          String      @id @default(cuid())
  videoId     String
  variantName String
  
  // 变体内容
  title       String
  caption     String?
  coverUrl    String?
  hookType    String?     // hook 类型：悬念、情感、冲突等
  ctaType     String?     // CTA 类型：立即观看、免费观看等
  hashtags    String[]
  extraData   Json?       // 额外配置
  
  status      VariantStatus @default(DRAFT)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // 关联
  video       Video       @relation(fields: [videoId], references: [id])
  publishTasks PublishTask[]
  performanceLogs PerformanceLog[]
  clickLogs   ClickLog[]

  @@unique([videoId, variantName])
  @@index([videoId])
  @@index([status])
  @@map("video_variants")
}

enum VariantStatus {
  DRAFT
  READY
  PUBLISHED
  ARCHIVED
}

// ===========================================
// 发布任务
// ===========================================

model PublishTask {
  id            String        @id @default(cuid())
  
  // 关联
  pageId        String
  videoId       String
  variantId     String
  
  // 排期信息
  scheduledAt   DateTime
  publishedAt   DateTime?
  
  // 状态
  status        TaskStatus    @default(PENDING)
  errorMessage  String?
  retryCount    Int           @default(0)
  
  // Facebook 信息
  fbPostId      String?
  fbVideoId     String?
  fbPostUrl     String?
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // 关联
  page          FacebookPage  @relation(fields: [pageId], references: [id])
  video         Video         @relation(fields: [videoId], references: [id])
  variant       VideoVariant  @relation(fields: [variantId], references: [id])
  performanceLogs PerformanceLog[]

  @@index([pageId])
  @@index([videoId])
  @@index([variantId])
  @@index([status])
  @@index([scheduledAt])
  @@map("publish_tasks")
}

enum TaskStatus {
  PENDING
  PROCESSING
  PUBLISHED
  FAILED
  CANCELED
}

// ===========================================
// 数据统计
// ===========================================

model PerformanceLog {
  id              String    @id @default(cuid())
  
  // 关联
  pageId          String
  videoId         String
  variantId       String
  publishTaskId   String?
  fbPostId        String?
  fbVideoId       String?
  
  // 数据指标
  views           Int       @default(0)
  reactions       Int       @default(0) // 点赞
  comments        Int       @default(0)
  shares          Int       @default(0)
  clicks          Int       @default(0)
  conversions     Int       @default(0)
  revenue         Decimal   @default(0) @db.Decimal(10, 2)
  
  // 日期
  date            DateTime  @db.Date
  createdAt       DateTime  @default(now())

  // 关联
  page            FacebookPage @relation(fields: [pageId], references: [id])
  video           Video        @relation(fields: [videoId], references: [id])
  variant         VideoVariant @relation(fields: [variantId], references: [id])
  publishTask     PublishTask? @relation(fields: [publishTaskId], references: [id])

  @@unique([pageId, videoId, variantId, date])
  @@index([pageId])
  @@index([videoId])
  @@index([variantId])
  @@index([date])
  @@map("performance_logs")
}

// ===========================================
// CPS 点击追踪
// ===========================================

model ClickLog {
  id          String    @id @default(cuid())
  
  // 追踪参数
  dramaId     String?
  pageId      String?
  videoId     String?
  variantId   String?
  
  // 请求信息
  ip          String?
  userAgent   String?
  referer     String?
  targetUrl   String
  
  // 地理信息（可选）
  country     String?
  city        String?
  
  createdAt   DateTime  @default(now())

  // 关联（可选）
  page        FacebookPage? @relation(fields: [pageId], references: [id])
  video       Video?        @relation(fields: [videoId], references: [id])
  variant     VideoVariant? @relation(fields: [variantId], references: [id])

  @@index([dramaId])
  @@index([pageId])
  @@index([videoId])
  @@index([variantId])
  @@index([createdAt])
  @@map("click_logs")
}

// ===========================================
// 主页健康日志
// ===========================================

model PageHealthLog {
  id          String    @id @default(cuid())
  pageId      String
  
  // 健康状态
  healthScore Int
  status      PageStatus
  
  // 检查详情
  tokenValid  Boolean?
  lastError   String?
  details     Json?
  
  createdAt   DateTime  @default(now())

  page        FacebookPage @relation(fields: [pageId], references: [id])

  @@index([pageId])
  @@index([createdAt])
  @@map("page_health_logs")
}

// ===========================================
// 系统设置
// ===========================================

model SystemSetting {
  id          String    @id @default(cuid())
  key         String    @unique
  value       String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("system_settings")
}
